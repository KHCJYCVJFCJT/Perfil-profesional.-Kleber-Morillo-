            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: url('https://via.placeholder.com/1920x600/2a9d8f/ffffff?text=Fondo+Profesional') no-repeat center center;
            background-size: cover;
            opacity: 0.1;
            z-index: 0;
