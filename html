    <style>
        :root {
            --primary-color: #2a9d8f;
            --secondary-color: #264653;
            --accent-color: #e9c46a;
            --background-color: #f4f4f4;
            --font-family: 'Roboto', sans-serif;
            --text-color: #264653;
            --card-bg: #fff;
        }
        [data-theme="dark"] {
            --primary-color: #4ecdc4;
            --secondary-color: #1a1a2e;
            --accent-color: #f9ca24;
            --background-color: #16213e;
            --text-color: #ddd;
