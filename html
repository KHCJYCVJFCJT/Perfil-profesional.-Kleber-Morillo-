            flex-wrap: wrap;
            gap: 1rem;
            margin-top: 1rem;
        }
        .skill {
            background: var(--primary-color);
            color: #fff;
            padding: 0.5rem 1rem;
            border-radius: 20px;
            font-size: 0.9rem;
            font-weight: 500;
        }
        .testimonials {
            background: linear-gradient(135deg, rgba(233,196,106,0.18), rgba(255,255,255,0.7));
